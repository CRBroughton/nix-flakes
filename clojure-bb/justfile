# Clojure + Babashka Project Commands
# Run 'just' to see all available commands
# Add your custom project commands below!

# List all available commands (default)
default:
    @just --list

# Start a Clojure REPL
repl:
    clj

# Start a Babashka REPL (faster startup)
bb-repl:
    bb --repl

# Run a Clojure file with the CLI
run file:
    clj -M {{file}}

# Run a Babashka script
bb-run file:
    bb {{file}}

# Run ClojureScript REPL (requires project setup)
cljs-repl:
    clj -M:cljs:dev

# Format code with cljfmt (add dependency to project first)
format:
    clj -M:cljfmt fix

# Lint code with clj-kondo
lint:
    clj-kondo --lint src

# Example: Add your custom commands here
# my-command:
#     echo "Running my custom command"
#     clj -M:my-alias
